# Anthropic (required)
ANTHROPIC_API_KEY=your_key_here

# Spitch — Nigerian language voice (required)
SPITCH_API_KEY=your_key_here
SPITCH_BASE_URL=https://api.spitch.app/v1

# WhatsApp — Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=thelaaw_secret_key
EVOLUTION_INSTANCE_NAME=thelaaw_bot

# App
SERVER_URL=http://your-ngrok-url.ngrok.app

# Paths (optional — defaults shown)
CHROMA_DB_PATH=backend/data/chroma
DATABASE_PATH=backend/data/thelaaw.db
